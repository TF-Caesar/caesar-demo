# CAESAR_SEARCH_API_KEY is required: Caesar's API is keyed. Get a key at
# https://trycaesar.com (new accounts include $1,000 in credits). The SDK also
# honors CAESAR_API_KEY as a fallback.
CAESAR_SEARCH_API_KEY=
# CAESAR_SEARCH_BASE_URL=https://alpha.api.trycaesar.com
# CLAIMS_LLM_KEY=        # Anthropic key; enables LLM claim extraction (Verifier). Off by default.
# VERIFIER_DEMO=1        # Force cached demo responses across all four demos (offline showcase / screenshots).
